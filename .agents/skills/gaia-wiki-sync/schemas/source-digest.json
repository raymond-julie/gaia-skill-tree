{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SourceDigest",
  "type": "object",
  "required": ["domain", "filesRead", "facts", "renames", "deprecations"],
  "properties": {
    "domain":     { "type": "string" },
    "filesRead":  { "type": "array", "items": { "type": "string" } },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "claim", "evidence"],
        "properties": {
          "id":       { "type": "string", "description": "dot-namespaced, e.g. cli.cmd.scan or schema.level.values" },
          "claim":    { "type": "string" },
          "evidence": { "type": "string", "description": "file:line or file#section" }
        }
      }
    },
    "renames": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "since"],
        "properties": {
          "from":  { "type": "string" },
          "to":    { "type": "string" },
          "since": { "type": "string" }
        }
      }
    },
    "deprecations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "terms, flags, or axes that no longer exist"
    }
  }
}
