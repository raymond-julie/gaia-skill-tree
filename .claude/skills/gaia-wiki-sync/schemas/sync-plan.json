{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SyncPlan",
  "type": "object",
  "required": ["syncWindow", "sourceDomains", "stalePages", "skipPages", "ciOwnedRegions"],
  "properties": {
    "syncWindow": {
      "type": "object",
      "required": ["since", "until"],
      "properties": {
        "since": { "type": "string", "description": "git sha or ISO date of last wiki sync" },
        "until": { "type": "string", "description": "usually HEAD" }
      }
    },
    "commitSummary": { "type": "string" },
    "sourceDomains": {
      "type": "object",
      "description": "keyed by domain name: cli, schema, named, policy, mcp",
      "additionalProperties": {
        "type": "object",
        "required": ["files", "affects"],
        "properties": {
          "files":   { "type": "array", "items": { "type": "string" } },
          "affects": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "stalePages":  { "type": "array", "items": { "type": "string" } },
    "skipPages":   { "type": "array", "items": { "type": "string" } },
    "ciOwnedRegions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["page", "startMarker", "endMarker", "policy"],
        "properties": {
          "page":        { "type": "string" },
          "startMarker": { "type": "string" },
          "endMarker":   { "type": "string" },
          "policy":      { "type": "string", "enum": ["preserve-verbatim"] }
        }
      }
    }
  }
}
