# Gaia Skill Registry — .gitignore

# feature-pipeline runtime state (local, per-machine)
.fp-state.json
.fp-handover.md
feature-pipeline-workspace/

# Externally installed agent skills (managed by `gaia skills install`)
.agents/skills/skill-creator

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
*.egg-info/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
.eggs/
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Claude Code agent worktrees (ephemeral isolated checkouts)
.claude/worktrees/
# Claude runtime lock files (machine-local PIDs — never commit)
.claude/scheduled_tasks.lock

# Impeccable live-edit session state (ephemeral DOM snapshots)
.impeccable/live/sessions/

# Plugin local cache
.gaia/
.gaia/skill-tree.cache.json
generated-output/

# Temp files
*.tmp
*.bak
scratch/
.hermes
perf_registry2/

# IDE and tooling machine-local state
.antigravitycli/
.pytest_cache/
scratch_context.json

# Generated registry pipeline artifacts (kept untracked in Git — regenerable from
# registry/nodes/ + registry/named/ sources via `gaia dev docs`).
/registry/gaia.json
/registry/gaia.gexf
/registry/gaia.svg
/registry/layouts_3d.json
/registry/named-skills.json
/registry/real-skills.json
/registry/real-skills.md
/base_gaia.json

# NOTE: docs/graph/ artifacts are website-served static assets, NOT pipeline
# byproducts. GitHub Pages publishes from main:/docs — files removed from git
# are removed from the live site. They MUST stay tracked. Re-tracked 2026-06-22
# after the #de3e77f7e untrack revealed the site went dark for /graph/gaia.json,
# /graph/named/index.json, /graph/gaia.gexf, /graph/gaia.svg.

# Bundled registry snapshot (regenerated at CI release time for vX.Y.0 wheels)
src/gaia_cli/data/registry/gaia.json
src/gaia_cli/data/registry/named-skills.json
src/gaia_cli/data/registry/named/
