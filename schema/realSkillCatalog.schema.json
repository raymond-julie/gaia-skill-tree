{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gaia-registry.github.io/schema/realSkillCatalog.schema.json",
  "title": "Gaia Real Skill Catalog",
  "description": "Curated source catalog for real-world named SKILL.md entries before promotion into the canonical Gaia graph.",
  "type": "object",
  "required": ["version", "updatedAt", "sources", "buckets"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "updatedAt": {
      "type": "string",
      "format": "date"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/source"
      }
    },
    "buckets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/bucket"
      }
    }
  },
  "definitions": {
    "source": {
      "type": "object",
      "required": ["id", "name", "url", "type", "notes"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "reportedSkillCount": {
          "type": "string"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "bucket": {
      "type": "object",
      "required": ["id", "name", "summary", "items"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/item"
          }
        }
      }
    },
    "item": {
      "type": "object",
      "required": ["name", "sourceId", "description", "mapsToGaia"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "sourceId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
        },
        "sourceUrl": {
          "type": "string",
          "format": "uri"
        },
        "detailUrl": {
          "type": "string",
          "format": "uri"
        },
        "path": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "mapsToGaia": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
          }
        }
      }
    }
  }
}
