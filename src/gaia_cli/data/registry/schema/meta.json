{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "description": "Gaia schema metadata — single source of truth for nomenclature, theming, and validation rules. Technical policy is documented in META.md.",
  "levels": {
    "order": [
      "0★",
      "1★",
      "2★",
      "3★",
      "4★",
      "5★",
      "6★"
    ],
    "labels": {
      "0★": "Basic",
      "1★": "Awakened",
      "2★": "Named",
      "3★": "Evolved",
      "4★": "Hardened",
      "5★": "Transcendent",
      "6★": "Apex"
    },
    "colors": {
      "0★": {
        "hex": "#94a3b8",
        "bg": "rgba(148,163,184,.12)",
        "border": "rgba(148,163,184,.4)"
      },
      "1★": {
        "hex": "#38bdf8",
        "bg": "rgba(56,189,248,.12)",
        "border": "rgba(56,189,248,.4)"
      },
      "2★": {
        "hex": "#63cab7",
        "bg": "rgba(99,202,183,.15)",
        "border": "rgba(99,202,183,.4)"
      },
      "3★": {
        "hex": "#a78bfa",
        "bg": "rgba(167,139,250,.15)",
        "border": "rgba(167,139,250,.4)"
      },
      "4★": {
        "hex": "#e879f9",
        "bg": "rgba(232,121,249,.15)",
        "border": "rgba(232,121,249,.4)"
      },
      "5★": {
        "hex": "#fbbf24",
        "bg": "rgba(251,191,36,.15)",
        "border": "rgba(251,191,36,.4)"
      },
      "6★": {
        "hex": "#fbbf24",
        "bg": "rgba(251,191,36,.22)",
        "border": "rgba(251,191,36,.55)"
      }
    },
    "evidenceFloors": {
      "0★": null,
      "1★": null,
      "2★": [
        "C",
        "B",
        "A"
      ],
      "3★": [
        "B",
        "A"
      ],
      "4★": [
        "B",
        "A"
      ],
      "5★": [
        "B",
        "A"
      ],
      "6★": [
        "A"
      ]
    }
  },
  "types": {
    "order": [
      "basic",
      "extra",
      "unique",
      "ultimate"
    ],
    "labels": {
      "basic": "Basic Skill",
      "extra": "Extra Skill",
      "unique": "Unique Skill",
      "ultimate": "Ultimate Skill"
    },
    "symbols": {
      "basic": "○",
      "extra": "◇",
      "unique": "◉",
      "ultimate": "◆"
    },
    "colors": {
      "basic": {
        "hex": "#38bdf8",
        "rgb": "56,189,248"
      },
      "extra": {
        "hex": "#c084fc",
        "rgb": "192,132,252"
      },
      "unique": {
        "hex": "#7c3aed",
        "rgb": "124,58,237"
      },
      "ultimate": {
        "hex": "#f59e0b",
        "rgb": "245,158,11"
      }
    },
    "minPrereqs": {
      "basic": 0,
      "extra": 2,
      "unique": 0,
      "ultimate": 5
    },
    "ultimateFusionCriteria": {
      "description": "All prerequisites must be named skills. The proposer must hold origin status on at least 1 of them.",
      "minNamedPrereqs": 5,
      "minOriginContributions": 1
    }
  },
  "evidence": {
    "classes": [
      "A",
      "B",
      "C"
    ],
    "ultimateMinSources": 3,
    "ultimateRequiredClasses": [
      "A",
      "B"
    ],
    "types": [
      "arxiv",
      "repo",
      "github-stars"
    ],
    "gradeThresholds": {
      "S": 90,
      "A": 80,
      "B": 60,
      "C": 40
    },
    "ultimateGate": {
      "minEvidencedComponents": 3,
      "requiredComponentGrades": {
        "S": 1,
        "A": 2
      },
      "componentFloor": "C"
    }
  },
  "demerits": {
    "order": [
      "broken-evidence",
      "niche-integration",
      "experimental-feature",
      "heavyweight-dependency"
    ],
    "labels": {
      "broken-evidence": "Broken evidence",
      "niche-integration": "Niche integrations",
      "experimental-feature": "Experimental features",
      "heavyweight-dependency": "Heavyweight dependencies"
    },
    "eligibleLevels": [
      "0★",
      "1★",
      "2★",
      "3★",
      "4★",
      "5★",
      "6★"
    ],
    "minimumEffectiveLevel": "0★"
  },
  "alternativePathways": {
    "4★": {
      "description": "Origin-fusion path: 3+ skill fuses with at least 1 origin named skill (alternative to evidence path).",
      "fusionPath": {
        "minFusions": 3,
        "minOriginContributions": 1
      }
    },
    "5★": {
      "description": "Ultimate path: Platform capstones requires 5+ named prerequisites + Origin Fusion + 10k repository stars.",
      "ultimatePath": {
        "minNamedPrereqs": 5,
        "minOriginContributions": 1,
        "minRepoStars": 10000
      }
    },
    "6★": {
      "description": "Apex path: Reaching Apex rank requires Tier A evidence and a fusion involving at least one Origin 5★ Transcendent skill.",
      "apexPath": {
        "minUltimateSkills": 1,
        "minUltimateLevel": "5★"
      }
    }
  },
  "customInstallation": {
    "eligibleLevels": [
      "4★",
      "5★",
      "6★"
    ],
    "minimumLevel": "4★",
    "alternativeUnlocks": {
      "skillSuite": {
        "description": "Fusion of 2 or more prerequisite skills where all component skills are installed altogether.",
        "minPrerequisites": 2,
        "requireAllPrerequisitesInstalled": true
      }
    }
  }
}