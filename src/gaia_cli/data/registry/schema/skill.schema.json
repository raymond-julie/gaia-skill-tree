{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gaia-registry.github.io/schema/skill.schema.json",
  "title": "Gaia Skill Node",
  "description": "Schema for a single skill node in the Gaia skill registry DAG.",
  "type": "object",
  "required": [
    "id",
    "name",
    "type",
    "description",
    "prerequisites",
    "derivatives",
    "knownAgents",
    "status",
    "createdAt",
    "updatedAt",
    "version"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
      "description": "Unique camelCase identifier for the skill."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable display name."
    },
    "title": {
      "type": "string",
      "description": "Optional lore title. For unclaimed ultimate skills, stored in the graph but not rendered in projections until a named implementation claims the skill."
    },
    "type": {
      "type": "string",
      "enum": [
        "basic",
        "extra",
        "unique",
        "ultimate"
      ],
      "description": "Skill classification type."
    },
    "summary": {
      "type": "string",
      "description": "A brief summary of the skill."
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "description": "Clear, agent-agnostic definition of the capability."
    },
    "useCase": {
      "type": "string",
      "description": "Detailed scenario of how a developer would use this skill."
    },
    "directives": {
      "type": "string",
      "description": "Specific guidelines or rules the skill follows during execution."
    },
    "prerequisites": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
      },
      "description": "Array of parent skill IDs required to unlock this skill."
    },
    "derivatives": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
      },
      "description": "Array of child skill IDs that this skill contributes to."
    },
    "conditions": {
      "type": "string",
      "description": "Optional free-text conditions required for fusion or level-up."
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/evidenceEntry"
      },
      "description": "Capability-level evidence for this abstract skill (e.g. Class A / academic sources describing the generic capability). Inherited by every named skill that points at this skill via genericSkillRef; named skills may add their own implementation-specific evidence."
    },
    "knownAgents": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of known agents that demonstrate this skill."
    },
    "status": {
      "type": "string",
      "enum": [
        "provisional",
        "validated",
        "disputed",
        "deprecated"
      ],
      "description": "Current validation status of the skill."
    },
    "createdAt": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 date when the skill was first added."
    },
    "updatedAt": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 date of last modification."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of this skill definition."
    },
    "timeline": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/timelineEvent"
      },
      "description": "Chronological history of meta-changes for this canonical skill."
    }
  },
  "definitions": {
    "evidenceEntry": {
      "type": "object",
      "required": [
        "class",
        "source",
        "evaluator",
        "date"
      ],
      "additionalProperties": false,
      "properties": {
        "class": {
          "type": "string",
          "enum": [
            "A",
            "B",
            "C"
          ],
          "description": "Evidence class: A (peer-reviewed), B (reproducible demo), C (credible demo)."
        },
        "source": {
          "type": "string",
          "format": "uri",
          "description": "URL to the evidence source."
        },
        "evaluator": {
          "type": "string",
          "description": "GitHub username of the person who evaluated the evidence."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "Date of evaluation."
        },
        "notes": {
          "type": "string",
          "description": "Optional notes about the evaluation."
        },
        "verified": {
          "type": "boolean",
          "description": "True if the evidence has been verified by a Verifier (4★+ contributor)."
        },
        "disputed": {
          "type": "boolean",
          "description": "True if the evidence is currently under dispute."
        },
        "verificationSource": {
          "type": "string",
          "format": "uri",
          "description": "URL to the verification discussion or PR."
        }
      }
    },
    "timelineEvent": {
      "type": "object",
      "required": [
        "timestamp",
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 date-time of the event."
        },
        "action": {
          "type": "string",
          "enum": [
            "rank_up",
            "fuse",
            "propose",
            "name",
            "demote",
            "ascend",
            "rejected",
            "merge",
            "split",
            "rename",
            "add",
            "evidence_added",
            "evidence_removed",
            "type_change",
            "verified",
            "disputed"
          ],
          "description": "The meta-action that occurred."
        },
        "contributor": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9-]*$",
          "description": "The GitHub username responsible for the change."
        },
        "details": {
          "type": "string",
          "description": "Additional context or human-readable details."
        },
        "previousValue": {
          "type": [
            "string",
            "null"
          ],
          "description": "The level/status before this event (e.g. '2★'). Null for first-time events such as 'add'."
        },
        "newValue": {
          "type": "string",
          "description": "The level/status after this event (e.g. '3★')."
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "basic"
          }
        }
      },
      "then": {
        "properties": {
          "prerequisites": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "extra"
          }
        }
      },
      "then": {
        "properties": {
          "prerequisites": {
            "minItems": 2
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "ultimate"
          }
        }
      },
      "then": {
        "properties": {
          "prerequisites": {
            "minItems": 3
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "unique"
          }
        }
      },
      "then": {
        "properties": {
          "prerequisites": {
            "maxItems": 0
          }
        }
      }
    }
  ]
}